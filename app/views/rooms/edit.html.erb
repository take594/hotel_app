<h2 class="display-5 text-primary">施設情報編集</h2>

<%= render 'shared/error_messages', obj: @room %>

<%= form_with model: @room do |f| %>
    <div class="form-group">
      <%= f.label :image, "施設画像" %><br>
      <% if @room.image.present? %>
        <%= image_tag @room.image.url %><br>
      <% else %>
        <%= image_tag 'defaultImage.png' %><br>
      <% end %>
      <%= f.file_field :image %>
    </div>
    <div class="form-group">
      <%= f.label :name, "施設名" %><br>
      <%= f.text_field :name, class:"form-control" %>
    </div>
    <div class="form-group">
      <%= f.label :introduction, "施設紹介" %><br>
      <%= f.text_area :introduction, class:"form-control" %>
    </div>
    <div class="form-group">
      <%= f.label :rate, "料金/日" %><br>
      <%= f.text_field :rate, class:"form-control" %>
    </div>
    <div class="form-group">
      <%= f.label  :located, "住所" %><br>
      <%= f.text_field :located, class:"form-control" %>
    </div>

    <div>
      <%= f.submit "登録完了する", class:"btn btn-primary" %>
    </div>
<% end %>

<div>  
  <%= link_to "施設一覧へ", rooms_path %>
</div>
