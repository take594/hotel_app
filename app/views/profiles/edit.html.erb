<h1 class="display-5 text-primary">プロフィール編集</h1>

<div>
  <%= link_to "アカウント情報", account_path, class: "btn btn-success" %>
  <%= link_to "プロフィール", profile_path, class: "btn btn-info" %>
</div>

<%= form_with model: @user, url: profile_path(current_user), local: true do |f| %>
  <%= render 'shared/error_messages', obj: @user %>
  <div class="form-group">
    <%= f.label :image, "プロフィール画像" %>
    <%= f.file_field :image %>

    <%= image_tag @user.image.thumb.url, size:'40*40' %>
  <div>
  <div class="form-group">
    <%= f.label :name, "名前" %>
    <%= f.text_field :name, class:"form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :self_introduction, "自己紹介" %>
    <%= f.text_area :self_introduction, class:"form-control" %>
  </div>

  <div>
    <%= f.submit "登録完了する", class:"btn btn-primary" %>
  </div>
<% end %>
