<h1>プロフィール</h1>

<div>
  <%= link_to "プロフィール編集", edit_profile_path, class: "btn btn-info" %>
  <%= link_to "アカウント情報", account_path, class: "btn btn-success" %>
</div>

<table class="table table-bordered">
  <tr>
    <th>プロフィール画像</th>
    <td>
      <% if current_user.image.present? %>
        <%= image_tag current_user.image.thumb.url, size: '40*40' %>
      <% else %>
        <%= image_tag 'default.png' %>
      <% end %>
    </td>
  </tr>
  <tr>
    <th>名前</th>
    <td><%= current_user.name %></td>
  </tr>
  <tr>
    <th>自己紹介</th> 
    <td><%= current_user.self_introduction %></td>
  </tr>
</table>

<div>
  <%= link_to "トップページに戻る", root_path %>
</div>
  