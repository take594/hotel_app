<%= form_with url:search_path, method: :get, local: true do |f| %>
  <div class="form-group">
    <%= f.label :search_mode, "検索方式を選択してください" %>
    <%= f.select :search_mode, options_for_select([["フリーワード検索","word_match"],["エリア検索","area_match"]]) %> 
  </div> 
  <div class="form-group">
    <%= f.label :word, "フリーワード検索はこちら" %>
    <%= f.text_field :word, class:"form-control" %>
  </div>
  <div class="form-group">
    <%= f.label :area, "エリア検索はこちら" %>
    <%= f.select :area, options_for_select([["東京", "東京"],["大阪", "大阪"], ["京都府", "京都府"], ["札幌", "札幌"]]) %>
  </div>
  <div>
    <%= f.submit "検索", class:"btn btn-primary" %>
  </div>
<% end %>
