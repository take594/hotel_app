<% if current_user.present? %>
  <% if current_user.own?(reservation) %>
    <div>
      <a class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#testModal" data-bs-backdrop="false">施設情報を削除する</a>
    </div>
    <div class="modal fade" id="testModal" tabindex="-1" role="dialog" aria-labelledby="basicModal" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h4><div class="modal-title" id="myModalLabel">削除確認画面</div></h4>
          </div>
          <div class="modal-body">
            <label>予約を削除しますか？</label>
          </div>
          <table class="table">
            <tr>
              <th>施設画像</th>
              <td><%= image_tag reservation.roomImage %></td>
            </tr>
            <tr>
              <th>施設名</th>
              <td><%= reservation.roomName %></td>
            </tr>
            <tr>
              <th>料金</th>
              <td><%= converting_to_jpy((reservation.roomRate.to_i)*(((reservation.checkOut - reservation.checkIn)/(24*60*60)).to_i)*(reservation.numberOfPeople.to_i)) %></td>
            </tr>
            <tr>
              <th>チェックイン日</th>
              <td><%= reservation.checkIn.to_s(:datetime_jp) %></td>
            </tr>
            <tr>
              <th>チェックアウト日</th>
              <td><%= reservation.checkOut.to_s(:datetime_jp) %></td>
            </tr>
            <tr>
              <th>宿泊人数</th>
              <td><%= reservation.numberOfPeople %>人</td>
            </tr>
          </table>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-bs-dismiss="modal">閉じる</button>
            <%= link_to "予約を削除する", reservation_path(reservation), method: :delete, class:"btn btn-danger" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% else %>
<% end %>
