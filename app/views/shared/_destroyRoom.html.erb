<% if current_user.present? %>
  <% if current_user.own?(room) %>
    <div>
      <a class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#testModal" data-bs-backdrop="false">施設情報を削除する</a>
    </div>
    <div class="modal fade" id="testModal" tabindex="-1" role="dialog" aria-labelledby="basicModal" aria-hidden="true">
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h4><div class="modal-title" id="myModalLabel">削除確認画面</div></h4>
          </div>
          <div class="modal-body">
            <label>施設を削除しますか？</label>
          </div>
          <table class="table">
            <tr>
              <th>施設名</th>
              <td><%= room.name %></td>
            </tr>
            <tr>
              <th>施設料金/日</th>
              <td><%= room.rate %></td>
            </tr>
            <tr>
              <th>施設画像</th>
              <td><%= image_tag room.image.url %></td>
            </tr>
          </table>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-bs-dismiss="modal">閉じる</button>
            <%= link_to "削除する", room_path(room), method: :delete, class:"btn btn-danger" %>
          </div>
        </div>
      </div>
    </div>
  <% else %>
  <% end %>
<% else %>
<% end %>
