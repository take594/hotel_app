<% if user_signed_in? %>

  <header>
    <span class="top_message">HOTEL NOW</span>
    <ul class="top_content">
      <li>
        <% if current_user.image.present? %>
          <%= image_tag current_user.image.thumb.url, size:'40*40' %>
        <% else %>
          <%= image_tag 'default.png', size: '40*40' %>
        <% end %>
      </li>
      <li>
        <div class="dropdown">
          <button type="button" class="btn btn-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <%= current_user.name %>
          </button>
          <ul class="dropdown-menu">
            <li><%=link_to "施設の新規登録", new_room_path, class:"dropdown-item"%></li>
            <li><%=link_to "予約済み施設一覧", reservations_path, class:"dropdown-item"%></li>
            <li><%=link_to "登録施設一覧", rooms_path, class:"dropdown-item"%></li>
            <li><%=link_to "アカウント情報", account_path, class:"dropdown-item"%></li>
            <li><%=link_to "ログアウト", destroy_user_session_path, method: :delete, class:"dropdown-item"%></li>
          </ul>
        </div>
      </li>
    </ul>
  </header>


  
  
<% else %>
  <header>
    <span class="top_message">HOTEL NOW</span>
    <ul class="top_content">
      <li class="log_in_page"><%=link_to "ログイン", new_user_session_path, class:"log_in_link"%></li>
      <li class="create_new_user"><%=link_to "新規登録", new_user_registration_path, class:"new_user_link"%></li>
    </ul>
  </header>

<% end %>

<%= render "shared/search" %>
