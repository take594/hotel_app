<h2 class="display-5 text-primary">予約情報編集</h2>

<%= render 'shared/error_messages', obj: @reservation %>

<%= form_with model: @reservation do |f| %>
    <div>
      <p>施設画像</p>
      <% if @reservation.roomImage.present? %>
        <%= image_tag @reservation.roomImage.url %>
      <% else %>
        <%= image_tag 'defaultImage.png' %>
      <% end %>
    </div>
    <div>
      <p>施設名</p>
      <%= @reservation.roomName %>
    </div>
    <div class="form-group">
      <%= f.label :checkIn, "チェックイン日" %><br>
      <%= f.date_field :checkIn, class:"form-control" %>
    </div>
    <div class="form-group">
      <%= f.label :checkOut, "チェックアウト日" %><br>
      <%= f.date_field :checkOut, class:"form-control" %>
    </div>
    <div class="form-group">
      <%= f.label :numberOfPeople, "宿泊人数" %><br>
      <%= f.text_area :numberOfPeople, class:"form-control" %>
    </div>


    <div>
      <%= f.submit "登録完了する", class:"btn btn-primary" %>
    </div>
<% end %>

<div>  
  <%= link_to "予約一覧へ", reservations_path %></li>
</div>
